# ---- Core ----
# Neon Postgres pooled connection string (use the -pooler host for serverless).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# 32+ char random string. Generate: openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-string
# Public URL of THIS CMS app (admin + API). Used for serverURL / CORS / links.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Public URL of the Astro web app. Used for SEO URLs, live preview, CORS allow-list.
PUBLIC_WEB_URL=http://localhost:4321
# Comma/space separated extra origins allowed for CORS/CSRF (add your web domain in prod).
PAYLOAD_ALLOWED_ORIGINS=http://localhost:4321

# ---- Media storage (S3-compatible: Cloudflare R2 / Vercel Blob / Supabase / AWS) ----
S3_BUCKET=media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://ACCOUNT.r2.cloudflarestorage.com
S3_REGION=auto
# Public base URL files are served from (served via web /media/* rewrite in prod).
S3_PUBLIC_URL=https://media.example.com

# ---- Email (Resend) ----
RESEND_API_KEY=

# ---- Deploy hook ----
# Vercel Deploy Hook for the WEB project. Pinged on publish to rebuild the static site.
DEPLOY_HOOK_URL=

# ---- Seeding ----
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
