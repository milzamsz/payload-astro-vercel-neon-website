{
  "name": "cms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed.ts",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload"
  },
  "dependencies": {
    "@img/sharp-libvips-linux-x64": "1.3.0",
    "@img/sharp-linux-x64": "0.35.1",
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/live-preview": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/plugin-form-builder": "3.85.1",
    "@payloadcms/plugin-nested-docs": "3.85.1",
    "@payloadcms/plugin-redirects": "3.85.1",
    "@payloadcms/plugin-search": "3.85.1",
    "@payloadcms/plugin-seo": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-s3": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.0",
    "next": "16.2.9",
    "payload": "3.85.1",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.12.4",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
