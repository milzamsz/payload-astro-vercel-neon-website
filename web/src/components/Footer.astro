---
import type { SiteSettings } from '@/lib/types'
interface Props {
  site: SiteSettings
}
const { site } = Astro.props
const year = new Date().getFullYear()
---

<footer class="border-t" style="border-color: var(--border);">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <p class="text-lg font-semibold tracking-tight">{site.logoText}</p>
        <p class="mt-3 max-w-xs text-sm" style="color: var(--fg-muted);">{site.description}</p>
        <a
          href={`mailto:${site.contactEmail}`}
          class="mt-4 inline-block text-sm"
          style="color: var(--color-accent);"
        >
          {site.contactEmail}
        </a>
      </div>

      {
        site.footerNav.map((col) => (
          <div>
            <p class="text-xs font-medium uppercase tracking-wider" style="color: var(--fg-muted);">
              {col.title}
            </p>
            <ul class="mt-3 space-y-2">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm" style="color: var(--fg);">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t pt-6 sm:flex-row sm:items-center"
      style="border-color: var(--border);"
    >
      <p class="text-sm" style="color: var(--fg-muted);">
        &copy; {year} {site.organization.legalName}. All rights reserved.
      </p>
      <div class="flex gap-4">
        {
          site.social.map((s) => (
            <a href={s.href} class="text-sm" style="color: var(--fg-muted);" rel="noopener" target="_blank">
              {s.platform}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
