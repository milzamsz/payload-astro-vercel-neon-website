---
import type { FAQBlock } from '@/lib/types'
interface Props {
  block: FAQBlock
}
const { block } = Astro.props
---

<section class="mx-auto max-w-3xl px-4 py-16 sm:px-6" data-reveal>
  {block.heading && <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{block.heading}</h2>}
  <div class="mt-8 divide-y" style="border-color: var(--border);">
    {
      block.items.map((item) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-medium">
            {item.question}
            <svg
              class="h-5 w-5 shrink-0 transition-transform group-open:rotate-45"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              style="color: var(--fg-muted);"
            >
              <path d="M12 5v14M5 12h14" />
            </svg>
          </summary>
          <p class="mt-3 leading-relaxed" style="color: var(--fg-muted);">
            {item.answer}
          </p>
        </details>
      ))
    }
  </div>
</section>
