---
import type { LogoCloudBlock } from '@/lib/types'
interface Props {
  block: LogoCloudBlock
}
const { block } = Astro.props
---

<section class="mx-auto max-w-6xl px-4 py-10 sm:px-6" data-reveal>
  {
    block.heading && (
      <p class="text-center text-sm" style="color: var(--fg-muted);">
        {block.heading}
      </p>
    )
  }
  <div class="mt-6 flex flex-wrap items-center justify-center gap-x-12 gap-y-6">
    {
      block.logos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.name}
          height="24"
          loading="lazy"
          class="h-6 w-auto opacity-60 transition hover:opacity-100 dark:invert"
        />
      ))
    }
  </div>
</section>
