---
import type { MediaBlock } from '@/lib/types'
interface Props {
  block: MediaBlock
}
const { block } = Astro.props
---

<section class="mx-auto max-w-5xl px-4 py-12 sm:px-6" data-reveal>
  <figure>
    <img
      src={block.image.url}
      alt={block.image.alt}
      width={block.image.width}
      height={block.image.height}
      loading="lazy"
      class="w-full rounded-[var(--radius-card)] object-cover"
    />
    {
      block.caption && (
        <figcaption class="mt-3 text-sm" style="color: var(--fg-muted);">
          {block.caption}
        </figcaption>
      )
    }
  </figure>
</section>
