---
import Layout from '@/layouts/Layout.astro'
import BlockRenderer from '@/components/blocks/BlockRenderer.astro'
import { legalPages } from '@/lib/content/legal'
import { getPage } from '@/lib/data'

const { slug } = Astro.params
const page = (await getPage(slug!)) ?? legalPages.find((p) => p.slug === slug)
if (!page) return Astro.redirect('/404')
---

<Layout title={page.title} description={page.seo?.description} noindex={page.seo?.noindex}>
  <section class="mx-auto max-w-3xl px-4 pt-16 sm:px-6">
    <h1 class="text-4xl font-semibold tracking-tighter md:text-5xl">{page.title}</h1>
  </section>
  <BlockRenderer blocks={page.blocks} />
</Layout>
