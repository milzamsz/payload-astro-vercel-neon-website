# Public site URL of THIS Astro app (used for canonical, sitemap, OG, RSS, JSON-LD).
PUBLIC_SITE_URL=http://localhost:4321

# ---- CMS connection (leave PUBLIC_CMS_URL blank to develop frontend-first on local content) ----
# Base URL of the Payload CMS app. When set, pages fetch published CMS content on each request.
PUBLIC_CMS_URL=
# Payload API key (users collection). Only needed for draft/live-preview fetches.
PAYLOAD_API_KEY=
# Shared secret used only by the /preview route and Payload live preview URLs.
PREVIEW_SECRET=
# Set to true temporarily if you want /api/diagnostics.json exposed.
ENABLE_DIAGNOSTICS=false

# ---- Analytics (also configurable via CMS Site Settings; env wins for local dev) ----
PUBLIC_GTM_ID=
PUBLIC_GA4_ID=
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=
